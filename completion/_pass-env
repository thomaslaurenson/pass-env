#compdef -P pass\ env*
# Zsh completion for the `pass env` extension
#
# Installation — add the completion/ directory to your fpath BEFORE compinit:
#
#   # ~/.zshrc
#   fpath=(/path/to/pass-env/completion $fpath)
#   autoload -Uz compinit && compinit
#
# Or copy this file to a directory already on your fpath, e.g.:
#   sudo cp _pass-env /usr/local/share/zsh/site-functions/    (macOS/Homebrew)
#   sudo cp _pass-env /usr/share/zsh/site-functions/          (Linux)

# Populate zsh completions with all pass entry paths from the store.
#
# Strips the .gpg suffix and sorts entries. Registered via compadd so zsh's
# completion system can apply path-component matching.
#
# Globals:
#   PASSWORD_STORE_DIR - root of the password store (default: ~/.password-store)
# Returns:
#   0 always
_pass_env_entries() {
  local password_store_dir="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
  [[ -d "$password_store_dir" ]] || return 0
  local -a entries
  entries=( "${(@f)$(
    find "$password_store_dir" -name '*.env.gpg' \( -type f -o -type l \) \
      | while IFS= read -r f; do printf '%s\n' "${f#"$password_store_dir/"}"; done \
      | sed 's/\.gpg$//' \
      | sort
  )}" )
  compadd -M 'r:|/=* r:|=*' -a entries
}

# Main zsh completion function for `pass env`.
#
# Handles subcommand completion and per-subcommand argument completion.
# Registered via the `#compdef -P pass\ env*` directive at the top of this
# file. Strips the leading `pass env` tokens from $words so $words[1] is
# always the subcommand.
#
# Returns:
#   0 always
_pass_env() {
  local state

  # Strip leading 'pass env' tokens so $words[1] is always the subcommand
  # when called via the #compdef pattern.
  local -a words
  words=( "${(@)words[3,-1]}" )   # words[1]=pass  words[2]=env  rest=ours
  local CURRENT=$(( CURRENT - 2 ))
  (( CURRENT < 1 )) && CURRENT=1

  local -a subcommands
  subcommands=(
    'run:load vars for a single command (vars do not persist)'
    'set:print export statements; eval to load vars into the current shell'
    'unset:print unset statements; eval to remove vars from the current shell'
    'list:print all .env entries available in the password store'
    'version:print the installed pass-env version'
    'help:show usage information'
  )

  _arguments -C \
    '1: :->subcmd' \
    '*:: :->args'

  case $state in
    subcmd)
      _describe 'subcommand' subcommands
      ;;

    args)
      case $words[1] in
        run)
          # Detect whether -- has already been supplied.
          # Everything after -- is the command to run — delegate completion to it.
          local ddash_idx=0 i
          for (( i = 2; i <= $#words; i++ )); do
            if [[ "${words[$i]}" == '--' ]]; then
              ddash_idx=$i
              break
            fi
          done

          if (( ddash_idx > 0 && CURRENT > ddash_idx )); then
            # After --: delegate to _command_offset so the command and its
            # arguments (files, flags, etc.) complete normally.
            _command_offset $(( ddash_idx + 1 ))
            return
          fi

          _arguments \
            '--entry=[pass entry path]:entry:_pass_env_entries' \
            '--[end of pass-env flags; COMMAND follows]' \
            '1:entry:_pass_env_entries'
          ;;

        set|unset)
          _arguments \
            '--entry=[pass entry path]:entry:_pass_env_entries' \
            '1:entry:_pass_env_entries'
          ;;

        help)
          return 0
          ;;

        *)
          _describe 'subcommand' subcommands
          ;;
      esac
      ;;
  esac
}

_pass_env "$@"

# Zsh completion function for the passenv shell function.
#
# Registered via `compdef _passenv passenv` below so it works independently
# of pass's own completion state. For the `unset` subcommand, completes from
# currently loaded entries in _PASSENV_TRACKER when available, falling back
# to all store entries when the tracker is empty.
#
# Globals:
#   _PASSENV_TRACKER - read for loaded entry names (unset subcommand)
#   PASSWORD_STORE_DIR - read indirectly by _pass_env_entries
# Returns:
#   0 always
_passenv() {
  local state

  local -a subcommands
  subcommands=(
    'set:load vars into the current shell (handles eval automatically)'
    'unset:remove vars from the current shell (handles eval automatically)'
    'run:load vars for a single command (vars do not persist)'
    'list:print all .env entries available in the password store'
    'loaded:print all entries currently loaded via passenv'
    'version:print the installed pass-env version'
    'help:show usage information'
  )

  _arguments -C \
    '1: :->subcmd' \
    '*:: :->args'

  case $state in
    subcmd)
      _describe 'subcommand' subcommands
      ;;

    args)
      case $words[1] in
        set)
          _arguments \
            '--entry=[pass entry path]:entry:_pass_env_entries' \
            '1:entry:_pass_env_entries'
          ;;

        unset)
          # Prefer loaded entries from the tracker; fall back to the full store.
          if (( ${#_PASSENV_TRACKER} > 0 )); then
            local -a loaded_keys
            loaded_keys=( "${(@k)_PASSENV_TRACKER}" )
            compadd -a loaded_keys
          else
            _pass_env_entries
          fi
          ;;

        run)
          # Detect whether -- has already been supplied.
          # Everything after -- is the command to run — delegate completion to it.
          local ddash_idx=0 i
          for (( i = 2; i <= $#words; i++ )); do
            if [[ "${words[$i]}" == '--' ]]; then
              ddash_idx=$i
              break
            fi
          done

          if (( ddash_idx > 0 && CURRENT > ddash_idx )); then
            # After --: delegate to _command_offset so the command and its
            # arguments (files, flags, etc.) complete normally.
            _command_offset $(( ddash_idx + 1 ))
            return
          fi

          _arguments \
            '--entry=[pass entry path]:entry:_pass_env_entries' \
            '--[end of passenv flags; COMMAND follows]' \
            '1:entry:_pass_env_entries'
          ;;

        list|loaded|version|help)
          # No further arguments.
          ;;

        *)
          _describe 'subcommand' subcommands
          ;;
      esac
      ;;
  esac
}

compdef _passenv passenv
